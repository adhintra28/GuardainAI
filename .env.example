# --- OpenAI (compliance scans) ---
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_COMPLIANCE_MODEL="gpt-4o-mini"

# --- App ---
PII_ENCRYPTION_KEY="replace-with-a-strong-random-secret"

# --- Clerk (authentication) ---
# Dashboard: https://dashboard.clerk.com → API Keys → copy publishable + secret.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Match embedded <SignIn /> / <SignUp /> routes (see src/app/auth/).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/auth"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/auth/sign-up"
# Post-auth redirects are set in src/app/layout.tsx (ClerkProvider). Do not set
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL / AFTER_SIGN_UP — they map to deprecated props and can confuse Clerk.

# --- Railway Postgres ---
# Railway’s database service usually exposes:
#   DATABASE_URL          — preferred for apps running *on* Railway (private network).
#   DATABASE_PUBLIC_URL   — TCP URL for clients *outside* Railway (your laptop, CI).
#
# Prisma only needs DATABASE_URL. You do not need a Railway variable named DIRECT_URL.
#
# Web service on Railway:
#   Add DATABASE_URL on your app and reference the Postgres plugin, e.g.
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
#   (Use the exact service name Railway shows: Postgres, PostgreSQL, etc.)
#
# Local dev (Prisma migrate, npm run dev) connecting to the same Railway DB:
#   Set DATABASE_URL in your local .env to DATABASE_PUBLIC_URL from the Railway DB UI
#   (or the “public” / external connection string), not the private URL, if the private
#   host is unreachable from your machine.
#
# If TLS errors: append  &sslmode=require  to the URL when needed.
#
# Local (Docker): `npm run db:up` then use:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/guardian?schema=public"
#
# Hosted: use a **public** Postgres URL (not Railway *.internal hostnames from a laptop).
DATABASE_URL="postgresql://postgres:PASSWORD@YOUR_HOST.railway.app:PORT/railway?schema=public"

# --- Redis (optional) ---
REDIS_URL="redis://127.0.0.1:6379"

# Run scans inside the API (no worker). Recommended on Railway without Redis.
COMPLIANCE_SCAN_SYNC="true"

# In `next dev`, scans run synchronously by default (no Redis/worker). Set to opt into BullMQ locally:
# USE_BULLMQ_IN_DEV="true"

# Optional: uploaded scan files directory (default: ./uploads)
# UPLOAD_DIR="/tmp/guardian-uploads"

// Single URL is enough for Railway Postgres and most hosts. If you later use a transaction
// pooler for `url`, add `directUrl = env("DIRECT_URL")` and point it at non-pooled Postgres.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum DocumentType {
  INVOICE
  BILL_OF_LADING
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  EMAIL_OTP
  CLERK
}

model AnalysisReport {
  id              String             @id @default(uuid())
  complianceScore Int
  riskLevel       String
  summary         String
  extractedData   Json?
  issuesList      Json?
  documents       UploadedDocument[]
  issues          ComplianceIssue[]
  createdAt       DateTime           @default(now())
}

model ComplianceDomain {
  id        String           @id
  label     String
  sortOrder Int              @default(0)
  acts      ComplianceAct[]
  jobs      AnalysisJob[]
}

model ComplianceAct {
  id        String           @id @default(uuid())
  domainId  String
  domain    ComplianceDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int              @default(0)

  @@index([domainId])
}

model AnalysisJob {
  id                 String             @id @default(uuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  idempotencyKey     String             @unique
  status             JobStatus          @default(QUEUED)
  traceId            String
  report             Json?
  extractedData      Json?
  errorMessage       String?
  complianceDomainId String?
  complianceDomain   ComplianceDomain?  @relation(fields: [complianceDomainId], references: [id], onDelete: SetNull)
  /// Stored upload metadata: [{ relativePath, originalName, mimeType }]
  inputFiles         Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([userId])
  @@index([complianceDomainId])
}

model UploadedDocument {
  id            String         @id @default(uuid())
  reportId      String
  report        AnalysisReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  documentType  DocumentType
  fileName      String
  mimeType      String?
  extractedJson Json?
  createdAt     DateTime       @default(now())

  @@index([reportId])
}

model ComplianceIssue {
  id             String         @id @default(uuid())
  reportId       String
  report         AnalysisReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  code           String
  title          String
  severity       IssueSeverity
  reason         String
  recommendation String
  createdAt      DateTime       @default(now())

  @@index([reportId])
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String?
  role          UserRole       @default(USER)
  mfaEnabled    Boolean        @default(true)
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
  mfaChallenges MfaChallenge[]
  analysisJobs  AnalysisJob[]
  providerAccounts AuthProviderAccount[]
}

model RefreshToken {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model MfaChallenge {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpHash    String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model AuthProviderAccount {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          AuthProvider
  providerAccountId String
  createdAt         DateTime     @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}
